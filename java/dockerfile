FROM eclipse-temurin:21-jdk-alpine AS builder
WORKDIR /app
RUN apk add --no-cache maven
COPY pom.xml .
COPY src/ src/
RUN mvn -q package -DskipTests

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=builder /app/target/crypto-benchmark-*.jar app.jar
ENTRYPOINT ["java", "-Xms512m", "-Xmx6g", "-XX:+UseG1GC", "-jar", "app.jar"]